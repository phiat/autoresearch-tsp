# Common commands for the tsp_heuristic autonomous loop.
# Invoke with `just <recipe>` from inside tsp_heuristic/.
# `just --list` to see all recipes.

set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set positional-arguments

# Show the recipe list (default).
default:
    @just --list --unsorted

# === Experiment cycle =====================================================

# Run one experiment with the 5-min budget. Output → run.log.
run:
    uv run solve.py > run.log 2>&1

# Pull the headline metrics from the last run.log.
metrics:
    @grep -E "^(val_cost|solve_seconds|total_seconds|n_cities):" run.log || \
        echo "no metrics in run.log — run crashed or never ran. Try: just crash"

# Show the tail of run.log for crash diagnosis.
crash:
    @tail -n 50 run.log

# Pretty-print the full results.tsv ledger.
ledger:
    @column -t -s $'\t' results.tsv

# Show the most recent logged experiment row.
last:
    @head -n 1 results.tsv | column -t -s $'\t'
    @tail -n 1 results.tsv | column -t -s $'\t'

# Append a row to results.tsv (inputs are positional):
#   just log <commit> <val_cost> <solve_seconds> <status> <description>
log COMMIT VAL_COST SOLVE_SECONDS STATUS DESCRIPTION:
    @printf '%s\t%s\t%s\t%s\t%s\n' "{{COMMIT}}" "{{VAL_COST}}" "{{SOLVE_SECONDS}}" "{{STATUS}}" "{{DESCRIPTION}}" >> results.tsv
    @echo "appended: {{COMMIT}}  {{VAL_COST}}  {{STATUS}}  {{DESCRIPTION}}"

# Commit a new experiment (description becomes the message body).
exp DESCRIPTION:
    git add -u solve.py
    git commit -m "exp: {{DESCRIPTION}}"

# Commit a tooling / harness change (used by the evolve-tooling skill).
meta DESCRIPTION:
    git add -A .claude/ ideas.md program.md justfile AGENTS.md
    git commit -m "meta: {{DESCRIPTION}}"

# Undo the most recent commit (use after a discarded experiment).
# Creates a revert commit on top instead of rewriting history — safe
# when sharing the branch with the tsp_neural loop.
revert:
    git revert HEAD --no-edit

# === Inspection ===========================================================

# Composite quick-view: branch, head commit, last result, recap-pending flag.
status:
    @echo "branch:      $(git branch --show-current)"
    @echo "head:        $(git log -1 --oneline)"
    @echo "results:     $(($(wc -l < results.tsv) - 1)) rows logged"
    @echo "last row:    $(tail -n 1 results.tsv | tr '\t' ' ')"
    @[ -f .recap-pending ] && echo "recap:       PENDING (cycle $(cat .recap-pending)) — run /recap" || echo "recap:       up to date"

# Compact git history of the experiment branch.
hist:
    @git log --oneline -20

# Diff solve.py between two commits (positional args, default last vs prev).
diff A="HEAD~1" B="HEAD":
    git diff "{{A}}" "{{B}}" -- solve.py

# Re-run the data smoke test (loads cities, scores identity tour).
data:
    uv run prepare.py

# Score an arbitrary tour CSV (one CityId per line, header "Path").
score CSV:
    @uv run python -c "import csv,numpy as np;from prepare import load_cities,score_tour;xy,ip=load_cities();r=csv.reader(open('{{CSV}}'));next(r);t=np.array([int(x[0]) for x in r],dtype=np.int64);print(f'{{CSV}}  val_cost = {score_tour(t,xy,ip):.4f}')"

# === Housekeeping =========================================================

# Remove transient artifacts (run.log, profile.log, .recap-pending sentinel).
clean:
    @rm -f run.log profile.log .recap-pending
    @echo "cleaned: run.log profile.log .recap-pending"

# Re-run the most recent solve.py state with K different ILS_SEED values.
# Backs the multi-seed-eval skill — invoke before discarding any
# experiment whose |val_cost - best| < 750.
multiseed K="3":
    @rm -f run.log.seed*
    @for s in $(seq 1 {{K}}); do \
        echo "  ILS_SEED=$s ..." ; \
        ILS_SEED=$s uv run solve.py > run.log.seed$s 2>&1 ; \
    done
    @echo
    @for s in $(seq 1 {{K}}); do \
        v=$(grep "^val_cost:" run.log.seed$s | awk '{print $2}') ; \
        printf "  seed=%s  val_cost=%s\n" "$s" "$v" ; \
    done

# Enumerate untested ideas in ideas.md (no matching id in results.tsv).
# Backs the untried-ideas skill — invoke when stuck-protocol triggers
# or when picking the next experiment to avoid saturated veins.
untried:
    @python3 ../scripts/untried_ideas.py

# Diagnostic: how many discards in a row, what's the current best, what was last keep.
stuck:
    @echo "branch:           $(git branch --show-current)"
    @echo "last keep:        $(awk -F'\t' 'NR>1 && $4=="keep" {print $1, $2}' results.tsv | tail -1)"
    @echo "discards since:   $(awk -F'\t' 'NR>1 {if($4=="keep")c=0; else c++} END{print c}' results.tsv)"
    @echo "best val_cost:    $(awk -F'\t' 'NR>1 && $4=="keep" {if(min==""||$2<min)min=$2}END{print min}' results.tsv)"
    @echo "total rows:       $(($(wc -l < results.tsv) - 1))"

# Print the project's tool inventory (skills, agents, slash commands, hooks).
tools:
    @echo "=== Slash commands ==="
    @ls -1 .claude/commands/ 2>/dev/null | sed 's/\.md$//' | sed 's/^/  \//'
    @echo
    @echo "=== Subagents ==="
    @ls -1 .claude/agents/ 2>/dev/null | sed 's/\.md$//' | sed 's/^/  /'
    @echo
    @echo "=== Skills ==="
    @ls -1 .claude/skills/ 2>/dev/null | sed 's/^/  /'
    @echo
    @echo "=== Hooks ==="
    @ls -1 .claude/hooks/ 2>/dev/null | sed 's/^/  /'
